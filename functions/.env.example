# Copia este archivo a functions/.env y completa los valores
# antes de desplegar (firebase deploy --only functions).

# Email donde Rami quiere recibir las peticiones de ciudad
NOTIFY_EMAIL=

# Remitente verificado en Resend (usa onboarding@resend.dev si aún
# no tienes un dominio verificado, pero solo llegará a la cuenta dueña
# del API key)
FROM_EMAIL=onboarding@resend.dev
