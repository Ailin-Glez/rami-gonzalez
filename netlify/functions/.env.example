# Estas variables se configuran en Netlify (Site settings > Environment
# variables), no en un archivo .env local para producción.
# Para probar localmente con `netlify dev`, puedes copiar esto a
# netlify/functions/.env (o a un .env en la raíz que netlify dev cargue).

RESEND_API_KEY=
NOTIFY_EMAIL=
FROM_EMAIL=onboarding@resend.dev
